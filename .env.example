# SmartFarm V15 Premium - Environment Configuration Template

# Application Environment
NODE_ENV=development
PORT=3000
DEBUG=smartfarm:*

# Database Configuration
DB_TYPE=sqlite
DB_PATH=./data/smartfarm.db
# For PostgreSQL:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=smartfarm
# DB_PASSWORD=your_password
# DB_NAME=smartfarm

# MQTT Configuration
MQTT_BROKER_URL=ws://localhost:9001
MQTT_USERNAME=admin
MQTT_PASSWORD=admin
MQTT_QOS=1
MQTT_RECONNECT_PERIOD=1000
MQTT_MAX_RECONNECT_DELAY=30000

# Security Configuration
JWT_SECRET=your-super-secure-secret-key-change-this-in-production
JWT_EXPIRY=24h
SESSION_TIMEOUT=1800000
ENABLE_HTTPS=false

# API Configuration
API_BASE_URL=http://localhost:3000/api
API_TIMEOUT=30000
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
CORS_CREDENTIALS=true

# Features
ENABLE_PWA=true
ENABLE_OFFLINE_MODE=true
ENABLE_PUSH_NOTIFICATIONS=false
ENABLE_DARK_MODE=true
ENABLE_ADVANCED_CHARTS=true
ENABLE_ADMIN_PANEL=true
ENABLE_DATA_EXPORT=true

# Logging
LOG_LEVEL=info
LOG_PERSIST=true
LOG_MAX_SIZE=10000

# Performance
CACHE_EXPIRY=86400000
MAX_STORAGE_SIZE=52428800
COMPRESSION_LEVEL=6

# Email Notifications (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@smartfarm.local

# Cloud Integration (Optional)
AWS_REGION=us-east-1
AWS_S3_BUCKET=smartfarm-backups
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# Monitoring
ENABLE_MONITORING=true
SENTRY_DSN=
DATADOG_API_KEY=

# Device Timeout
DEVICE_HEARTBEAT_TIMEOUT=300000
SENSOR_READ_TIMEOUT=10000

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf

# Timezone
TZ=Asia/Bangkok

# Custom Variables
APP_NAME=SmartFarm V15 Premium
APP_VERSION=15.0.0
COMPANY_NAME=Your Company Name
COMPANY_EMAIL=support@yourcompany.com
